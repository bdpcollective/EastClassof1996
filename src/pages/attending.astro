---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Banner from '../components/Banner.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout
  title="Who's Attending | Lincoln East High School Class of 1996"
  description="See who's coming to the Lincoln East High School Class of 1996 30th Reunion in September 2026!"
>
  <Header />
  <Banner />

  <main id="main-content">
    <section class="attending-page ambient-bg">
      <div class="container">
        <div class="attending-header animate-on-scroll">
          <h1>Who's Coming</h1>
          <p class="attending-subtitle">Classmates who have registered for the reunion</p>
          <div class="event-details">
            <div class="detail-item">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
              <span>Friday - Sunday, September 4-6, 2026</span>
            </div>
            <div class="detail-item">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
              <span>Lincoln, Nebraska</span>
            </div>
          </div>
        </div>

        <div class="attending-content">
          <!-- Loading State -->
          <div id="loadingState" class="loading-state">
            <div class="spinner"></div>
            <p>Loading attendees...</p>
          </div>

          <!-- Error State -->
          <div id="errorState" class="error-state" hidden>
            <p>Unable to load the attendee list right now. Please try again later.</p>
            <button id="retryBtn" class="retry-btn">Try Again</button>
          </div>

          <!-- Attendee List -->
          <div id="attendeeList" class="attendee-list" hidden>
            <div class="attendee-count">
              <span id="attendeeCount">0</span> classmates registered
            </div>
            <div id="attendeeGrid" class="attendee-grid"></div>
            <div class="cta-section">
              <p>Don't see your name?</p>
              <a href="/register" class="register-btn">Register Now</a>
            </div>
          </div>

          <!-- Empty State -->
          <div id="emptyState" class="empty-state" hidden>
            <p>No registrations yet — be the first!</p>
            <a href="/register" class="register-btn">Register Now</a>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />

  <script>
    const GOOGLE_SHEETS_URL = 'https://script.google.com/macros/s/AKfycbw0K6R1AVn_qgLNFwWL-Ofoi55yDepYUN5Pwpy7RpkS1yOtjsU0Pky5STBWuU3k5r0KHQ/exec';

    function rowToAttendee(row) {
      const firstName = (row[1] || '').toString().trim();
      const lastName = (row[2] || '').toString().trim();
      if (!firstName) return null;
      const lastInitial = lastName ? lastName.charAt(0).toUpperCase() + '.' : '';
      return { name: firstName + ' ' + lastInitial, timestamp: row[0] };
    }

    function parseAttendees(data) {
      // Format 1: {attendees: [{name: "Brian P."}]}
      if (data.attendees && data.attendees.length > 0) {
        return data.attendees;
      }

      // Format 2: {rows: [[...], [...]]}
      if (data.rows && data.rows.length > 0) {
        return data.rows.map(rowToAttendee).filter(Boolean);
      }

      // Format 3: {headers: [...], allRows: [[...], [...]]}
      if (data.allRows && data.allRows.length > 0) {
        return data.allRows.map(rowToAttendee).filter(Boolean);
      }

      // Format 4: debug format {headers, firstRow, totalRows}
      if (data.firstRow) {
        const attendee = rowToAttendee(data.firstRow);
        return attendee ? [attendee] : [];
      }

      return [];
    }

    async function fetchAttendees() {
      const loadingState = document.getElementById('loadingState');
      const errorState = document.getElementById('errorState');
      const attendeeList = document.getElementById('attendeeList');
      const emptyState = document.getElementById('emptyState');

      loadingState.hidden = false;
      errorState.hidden = true;
      attendeeList.hidden = true;
      emptyState.hidden = true;

      try {
        const response = await fetch(GOOGLE_SHEETS_URL, {
          method: 'GET',
          mode: 'cors',
        });

        const data = await response.json();
        loadingState.hidden = true;

        const attendees = parseAttendees(data);

        if (attendees.length === 0) {
          emptyState.hidden = false;
          return;
        }

        renderAttendees(attendees);
        attendeeList.hidden = false;
      } catch (error) {
        console.error('Error fetching attendees:', error);
        loadingState.hidden = true;
        errorState.hidden = false;
      }
    }

    function renderAttendees(attendees) {
      const grid = document.getElementById('attendeeGrid');
      const count = document.getElementById('attendeeCount');

      count.textContent = attendees.length.toString();

      grid.innerHTML = attendees
        .sort((a, b) => new Date(b.timestamp) - new Date(a.timestamp))
        .map((attendee, index) => `
          <div class="attendee-card">
            <span class="attendee-number">${index + 1}.</span>
            <span class="attendee-name">${attendee.name}</span>
          </div>
        `).join('');
    }

    document.getElementById('retryBtn')?.addEventListener('click', fetchAttendees);
    document.addEventListener('DOMContentLoaded', fetchAttendees);
  </script>
</BaseLayout>

<style>
  .attending-page {
    padding: var(--section-padding) 0;
    background: var(--gradient-primary);
    min-height: 80vh;
  }

  .attending-page::before {
    z-index: 0;
  }

  .container {
    max-width: 900px;
    margin: 0 auto;
    padding: 0 20px;
    position: relative;
    z-index: 1;
  }

  .attending-header {
    text-align: center;
    margin-bottom: 60px;
  }

  .attending-header h1 {
    font-family: var(--font-display);
    font-size: 48px;
    font-weight: 600;
    color: white;
    margin: 0 0 20px 0;
    text-transform: uppercase;
    letter-spacing: 2px;
  }

  .attending-subtitle {
    font-family: var(--font-body);
    font-size: 20px;
    font-weight: 300;
    color: rgba(255, 255, 255, 0.9);
    margin: 0 0 40px 0;
  }

  .event-details {
    display: flex;
    justify-content: center;
    gap: 40px;
    flex-wrap: wrap;
  }

  .detail-item {
    display: flex;
    align-items: center;
    gap: 10px;
    font-family: var(--font-body);
    color: white;
    font-weight: 500;
  }

  .detail-item svg {
    color: var(--color-electric-light);
  }

  .attending-content {
    background: white;
    border-radius: 16px;
    padding: 40px;
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.15);
  }

  /* Loading State */
  .loading-state {
    text-align: center;
    padding: 60px 20px;
  }

  .spinner {
    width: 40px;
    height: 40px;
    border: 3px solid var(--color-gray-200);
    border-top-color: var(--color-electric);
    border-radius: 50%;
    animation: spin 0.8s linear infinite;
    margin: 0 auto 16px;
  }

  @keyframes spin {
    to { transform: rotate(360deg); }
  }

  .loading-state p {
    font-family: var(--font-body);
    color: var(--color-gray-500);
    font-size: 16px;
    margin: 0;
  }

  /* Error State */
  .error-state {
    text-align: center;
    padding: 60px 20px;
  }

  .error-state p {
    font-family: var(--font-body);
    color: var(--color-gray-500);
    font-size: 16px;
    margin: 0 0 20px 0;
  }

  .retry-btn {
    background: var(--gradient-primary);
    color: white;
    border: none;
    padding: 12px 24px;
    border-radius: 10px;
    font-family: var(--font-display);
    font-size: 14px;
    font-weight: 600;
    cursor: pointer;
    text-transform: uppercase;
    letter-spacing: 1px;
    transition: all var(--transition-medium);
  }

  .retry-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(6, 182, 212, 0.3);
  }

  /* Attendee Count */
  .attendee-count {
    text-align: center;
    font-family: var(--font-display);
    font-size: 18px;
    color: var(--color-primary-700);
    font-weight: 600;
    margin-bottom: 32px;
    padding-bottom: 20px;
    border-bottom: 2px solid var(--color-gray-100);
  }

  .attendee-count span {
    font-size: 28px;
    color: var(--color-electric);
  }

  /* Attendee Grid */
  .attendee-grid {
    display: flex;
    flex-direction: column;
    gap: 12px;
    margin-bottom: 40px;
  }

  .attendee-card {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 12px 16px;
    background: var(--color-gray-50, #f9fafb);
    border-radius: 10px;
    transition: all var(--transition-fast);
  }

  .attendee-card:hover {
    background: rgba(6, 182, 212, 0.06);
    transform: translateY(-1px);
  }

  .attendee-avatar {
    width: 36px;
    height: 36px;
    background: var(--gradient-primary);
    color: white;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 14px;
    flex-shrink: 0;
  }

  .attendee-number {
    font-family: var(--font-body);
    font-size: 15px;
    color: var(--color-gray-400);
    font-weight: 600;
    min-width: 28px;
  }

  .attendee-name {
    font-family: var(--font-body);
    font-size: 15px;
    color: var(--color-gray-700);
    font-weight: 500;
  }

  /* CTA Section */
  .cta-section {
    text-align: center;
    padding-top: 32px;
    border-top: 2px solid var(--color-gray-100);
  }

  .cta-section p {
    font-family: var(--font-body);
    font-size: 16px;
    color: var(--color-gray-500);
    margin: 0 0 16px 0;
  }

  .register-btn {
    display: inline-block;
    background: var(--gradient-primary);
    color: white;
    padding: 14px 32px;
    border-radius: 12px;
    font-family: var(--font-display);
    font-size: 16px;
    font-weight: 600;
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 1px;
    transition: all var(--transition-medium);
    box-shadow: 0 4px 15px rgba(6, 182, 212, 0.2);
  }

  .register-btn:hover {
    transform: translateY(-3px);
    box-shadow: 0 10px 30px rgba(6, 182, 212, 0.3);
  }

  /* Empty State */
  .empty-state {
    text-align: center;
    padding: 60px 20px;
  }

  .empty-state p {
    font-family: var(--font-body);
    font-size: 18px;
    color: var(--color-gray-500);
    margin: 0 0 24px 0;
  }

  @media (max-width: 768px) {
    .attending-header h1 { font-size: 32px; }
    .event-details { flex-direction: column; align-items: center; gap: 20px; }
    .attending-content { padding: 30px 20px; }
    .attendee-grid { gap: 10px; }
    .register-btn { width: 100%; text-align: center; }
  }

  @media (max-width: 480px) {
    .attending-page { padding: 40px 0; }
    .attending-header h1 { font-size: 24px; }
    .attending-subtitle { font-size: 16px; }
    .attendee-grid { gap: 8px; }
  }
</style>
