---
// Banner component - modernized with gradient and texture
---

<div class="banner">
  <div class="container">
    <div class="banner-section banner-left">
      <p>30TH HIGH</p>
      <p>SCHOOL REUNION</p>
    </div>
    <div class="banner-section banner-center">
      <p class="class-year">CLASS OF 1996</p>
    </div>
    <div class="banner-section banner-right">
      <p>LINCOLN</p>
      <p>NEBRASKA</p>
    </div>
  </div>
</div>

<style>
  .banner {
    background: var(--gradient-primary);
    color: white;
    padding: 36px 0;
    position: relative;
    overflow: hidden;
  }

  .banner::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      repeating-linear-gradient(45deg, transparent, transparent 30px, rgba(255,255,255,0.02) 30px, rgba(255,255,255,0.02) 60px);
    pointer-events: none;
  }

  .banner .container {
    max-width: var(--container-max);
    margin: 0 auto;
    padding: 0 20px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    position: relative;
    z-index: 1;
  }

  .banner-section {
    text-align: center;
    padding: 0 32px;
  }

  .banner-left {
    flex: 0.5;
    border-right: 1px solid rgba(255, 255, 255, 0.2);
  }

  .banner-center {
    flex: 3;
    border-right: 1px solid rgba(255, 255, 255, 0.2);
  }

  .banner-right {
    flex: 0.5;
  }

  .banner-section p {
    margin: 0;
    font-family: var(--font-display);
    font-weight: 500;
    letter-spacing: 1px;
  }

  .banner-left p {
    font-size: 16px;
    line-height: 1.3;
  }

  .banner-right p {
    font-size: 16px;
    line-height: 1.3;
  }

  .class-year {
    font-family: var(--font-accent);
    font-size: clamp(24px, 8vw, 84px);
    font-weight: 700;
    line-height: 1;
    text-shadow:
      0 0 20px rgba(255, 255, 255, 0.3),
      0 0 40px rgba(6, 182, 212, 0.2);
  }

  @media (min-width: 1920px) {
    .banner .container { max-width: 1600px; }
    .class-year { font-size: 96px; }
  }

  @media (max-width: 768px) {
    .banner { padding: 24px 0; }
    .banner-section { padding: 0 16px; }
    .banner-left p,
    .banner-right p { font-size: 14px; }
  }

  @media (max-width: 480px) {
    .banner { padding: 16px 0; }
    .banner-section { padding: 0 6px; }
    .banner-left p,
    .banner-right p { font-size: 9px; line-height: 1.1; }
  }

  @media (max-width: 390px) {
    .banner-left p,
    .banner-right p { font-size: 8px; }
    .banner-section { padding: 0 3px; }
  }

  @media (max-width: 320px) {
    .banner { padding: 12px 0; }
    .banner-left p,
    .banner-right p { font-size: 7px; }
    .banner-section { padding: 0 2px; }
  }
</style>
