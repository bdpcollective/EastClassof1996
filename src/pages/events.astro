---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Banner from '../components/Banner.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout
  title="Events | Lincoln East High School Class of 1996"
  description="View all reunion events for the Lincoln East High School Class of 1996 30th Reunion. School tour and social events."
>
  <Header />
  <Banner />

  <main id="main-content">
    <section class="events-page ambient-bg">
      <div class="container">
        <div class="section-header">
          <h2 class="section-title">REUNION EVENTS</h2>
          <div class="title-accent"></div>
        </div>
        <div class="events-grid animate-on-scroll stagger">
          <div class="event-card">
            <div class="event-card-top">
              <div class="event-date">
                <span class="day-name">SAT</span>
                <span class="month">SEP</span>
                <span class="day">5</span>
              </div>
              <div class="event-details">
                <h3>School Tour</h3>
                <p class="time">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                  8:00 AM - 10:00 AM
                </p>
                <p class="location">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
                  Lincoln East High School
                </p>
                <p class="address">1000 S 70th St, Lincoln, NE 68510</p>
                <p class="description">Take a nostalgic walk through the halls of Lincoln East and see how things have changed. Coffee and donuts will be provided.</p>
                <div class="add-to-calendar">
                  <button class="calendar-btn" aria-expanded="false" aria-haspopup="true">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                    Add to Calendar
                  </button>
                  <div class="calendar-dropdown" role="menu">
                    <a role="menuitem" href="#" class="calendar-option" data-calendar="google" data-title="School Tour - Class of 1996 Reunion" data-start="20260905T130000Z" data-end="20260905T150000Z" data-location="Lincoln East High School, 1000 S 70th St, Lincoln, NE 68510" data-description="Take a nostalgic walk through the halls of Lincoln East and see how things have changed. Coffee and donuts will be provided.">
                      Google Calendar
                    </a>
                    <a role="menuitem" href="#" class="calendar-option" data-calendar="ics" data-title="School Tour - Class of 1996 Reunion" data-start="20260905T130000Z" data-end="20260905T150000Z" data-location="Lincoln East High School, 1000 S 70th St, Lincoln, NE 68510" data-description="Take a nostalgic walk through the halls of Lincoln East and see how things have changed. Coffee and donuts will be provided.">
                      Apple / Outlook (.ics)
                    </a>
                  </div>
                </div>
              </div>
            </div>
            <div class="event-map">
              <iframe
                src="https://maps.google.com/maps?q=Lincoln+East+High+School,+1000+S+70th+St,+Lincoln,+NE+68510&t=&z=15&ie=UTF8&iwloc=&output=embed"
                width="100%"
                height="200"
                style="border:0;"
                allowfullscreen=""
                loading="lazy"
                referrerpolicy="no-referrer-when-downgrade"
                title="Map to Lincoln East High School"
              ></iframe>
            </div>
          </div>

          <div class="event-card">
            <div class="event-card-top">
              <div class="event-date">
                <span class="day-name">SUN</span>
                <span class="month">SEP</span>
                <span class="day">6</span>
              </div>
              <div class="event-details">
                <h3>Sunday Social | South Apothecary Loft</h3>
                <p class="time">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                  7:00 PM - 10:00 PM
                </p>
                <p class="location">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
                  South Apothecary Loft
                </p>
                <p class="address">140 N. 8th Street, Suite 501, Lincoln, NE 68508</p>
                <p class="description">Join us for a casual social gathering to reconnect with classmates.</p>
                <div class="add-to-calendar">
                  <button class="calendar-btn" aria-expanded="false" aria-haspopup="true">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                    Add to Calendar
                  </button>
                  <div class="calendar-dropdown" role="menu">
                    <a role="menuitem" href="#" class="calendar-option" data-calendar="google" data-title="Sunday Social - Class of 1996 Reunion" data-start="20260907T000000Z" data-end="20260907T030000Z" data-location="South Apothecary Loft, 140 N. 8th Street, Suite 501, Lincoln, NE 68508" data-description="Join us for a casual social gathering to reconnect with classmates.">
                      Google Calendar
                    </a>
                    <a role="menuitem" href="#" class="calendar-option" data-calendar="ics" data-title="Sunday Social - Class of 1996 Reunion" data-start="20260907T000000Z" data-end="20260907T030000Z" data-location="South Apothecary Loft, 140 N. 8th Street, Suite 501, Lincoln, NE 68508" data-description="Join us for a casual social gathering to reconnect with classmates.">
                      Apple / Outlook (.ics)
                    </a>
                  </div>
                </div>
              </div>
            </div>
            <div class="event-map">
              <iframe
                src="https://maps.google.com/maps?q=140+N+8th+Street+Suite+501,+Lincoln,+NE+68508&t=&z=15&ie=UTF8&iwloc=&output=embed"
                width="100%"
                height="200"
                style="border:0;"
                allowfullscreen=""
                loading="lazy"
                referrerpolicy="no-referrer-when-downgrade"
                title="Map to South Apothecary Loft"
              ></iframe>
            </div>
          </div>
        </div>

        <div class="rsvp-button-container">
          <a href="/rsvp" class="rsvp-button">RSVP NOW</a>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>

<style>
  .events-page {
    padding: var(--section-padding) 0;
    background: var(--gradient-primary);
    min-height: 80vh;
  }

  .events-page::before {
    z-index: 0;
  }

  .container {
    max-width: var(--container-max);
    margin: 0 auto;
    padding: 0 20px;
    position: relative;
    z-index: 1;
  }

  .section-header {
    text-align: center;
    margin-bottom: 60px;
  }

  .section-title {
    font-family: var(--font-display);
    font-size: 48px;
    font-weight: 600;
    color: white;
    text-align: center;
    margin: 0 0 16px 0;
    text-transform: uppercase;
    letter-spacing: 4px;
  }

  .title-accent {
    width: 60px;
    height: 3px;
    background: var(--gradient-card-border);
    margin: 0 auto;
    border-radius: 2px;
  }

  .events-grid {
    display: flex;
    flex-direction: column;
    gap: 40px;
    margin-bottom: 60px;
  }

  .event-card {
    background: white;
    border-radius: 16px;
    overflow: hidden;
    transition: transform var(--transition-medium), box-shadow var(--transition-medium);
    position: relative;
  }

  .event-card-top {
    display: flex;
    gap: 30px;
    padding: 32px;
  }

  .event-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 12px 30px rgba(0, 0, 0, 0.1);
  }

  .event-date {
    background: var(--gradient-primary);
    color: white;
    border-radius: 12px;
    padding: 12px;
    text-align: center;
    width: 100px;
    height: 100px;
    flex-shrink: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
  }

  .event-date .day-name {
    display: block;
    font-family: var(--font-display);
    font-size: 16px;
    font-weight: 600;
    letter-spacing: 2px;
    opacity: 0.85;
  }

  .event-date .month {
    display: block;
    font-family: var(--font-display);
    font-size: 16px;
    font-weight: 500;
    margin-top: 0;
    letter-spacing: 1px;
  }

  .event-date .day {
    display: block;
    font-family: var(--font-display);
    font-size: 36px;
    font-weight: 700;
    line-height: 1;
    margin-top: 4px;
  }

  .event-details h3 {
    font-family: var(--font-display);
    font-size: 24px;
    font-weight: 600;
    color: var(--color-primary-700);
    margin: 0 0 12px 0;
  }

  .event-details .time,
  .event-details .location {
    font-family: var(--font-body);
    font-size: 14px;
    color: var(--color-gray-500);
    margin: 0 0 5px 0;
    font-weight: 500;
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .event-details .time svg,
  .event-details .location svg {
    flex-shrink: 0;
    color: var(--color-electric);
  }

  .event-details .address {
    font-family: var(--font-body);
    font-size: 13px;
    color: var(--color-gray-500);
    margin: 0 0 15px 0;
    padding-left: 20px;
  }

  .event-details .description {
    font-family: var(--font-body);
    font-size: 16px;
    color: var(--color-gray-500);
    line-height: 1.6;
    margin: 0;
  }

  .rsvp-button-container {
    text-align: center;
  }

  .rsvp-button {
    display: inline-block;
    background: white;
    color: var(--color-primary-700);
    padding: 16px 48px;
    border-radius: 12px;
    text-decoration: none;
    font-family: var(--font-display);
    font-size: 18px;
    font-weight: 600;
    letter-spacing: 1px;
    transition: all var(--transition-medium);
  }

  .rsvp-button:hover {
    transform: translateY(-3px);
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.2);
  }

  .event-map iframe {
    display: block;
    width: 100%;
    height: 200px;
  }

  .add-to-calendar {
    position: relative;
    margin-top: 16px;
  }

  .calendar-btn {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: none;
    border: 1.5px solid var(--color-electric);
    color: var(--color-electric);
    padding: 8px 16px;
    border-radius: 8px;
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 600;
    cursor: pointer;
    transition: all var(--transition-medium);
  }

  .calendar-btn:hover {
    background: var(--color-electric);
    color: white;
  }

  .calendar-dropdown {
    display: none;
    position: absolute;
    bottom: calc(100% + 8px);
    left: 0;
    background: white;
    border-radius: 10px;
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.15);
    overflow: hidden;
    z-index: 10;
    min-width: 200px;
  }

  .calendar-dropdown.open {
    display: block;
  }

  .calendar-option {
    display: block;
    padding: 12px 16px;
    text-decoration: none;
    color: var(--color-primary-700);
    font-family: var(--font-body);
    font-size: 14px;
    font-weight: 500;
    transition: background var(--transition-fast);
  }

  .calendar-option:hover {
    background: rgba(6, 182, 212, 0.08);
  }

  @media (min-width: 1920px) {
    .container { max-width: 1600px; }
    .section-title { font-size: 56px; }
    .event-card-top { padding: 40px; }
    .event-details h3 { font-size: 28px; }
    .event-details .description { font-size: 18px; }
  }

  @media (max-width: 768px) {
    .events-page { padding: var(--section-padding-mobile) 0; }
    .section-title { font-size: 36px; }
    .events-grid { gap: 30px; }
    .event-card-top { flex-direction: column; padding: 24px; }
    .event-date { width: 100%; max-width: 120px; margin: 0 auto 20px auto; }
    .event-details { text-align: center; }
    .event-details .time,
    .event-details .location { justify-content: center; }
    .event-details .address { padding-left: 0; }
    .add-to-calendar { display: flex; justify-content: center; }
    .calendar-dropdown { left: 50%; transform: translateX(-50%); }
    .rsvp-button { font-size: 16px; padding: 14px 40px; }
  }

  @media (max-width: 480px) {
    .events-page { padding: 40px 0; }
    .section-title { font-size: 28px; margin: 0 0 12px 0; }
    .event-card-top { padding: 16px; }
    .event-date { padding: 15px; }
    .event-date .day { font-size: 28px; }
    .event-details h3 { font-size: 20px; }
    .event-details .description { font-size: 14px; }
    .rsvp-button { font-size: 14px; padding: 12px 30px; }
  }
</style>

<script>
  document.querySelectorAll('.calendar-btn').forEach(btn => {
    btn.addEventListener('click', (e) => {
      e.stopPropagation();
      const dropdown = btn.nextElementSibling;
      const isOpen = dropdown.classList.contains('open');

      // Close all dropdowns
      document.querySelectorAll('.calendar-dropdown').forEach(d => d.classList.remove('open'));
      document.querySelectorAll('.calendar-btn').forEach(b => b.setAttribute('aria-expanded', 'false'));

      if (!isOpen) {
        dropdown.classList.add('open');
        btn.setAttribute('aria-expanded', 'true');
      }
    });
  });

  // Close dropdowns when clicking outside
  document.addEventListener('click', () => {
    document.querySelectorAll('.calendar-dropdown').forEach(d => d.classList.remove('open'));
    document.querySelectorAll('.calendar-btn').forEach(b => b.setAttribute('aria-expanded', 'false'));
  });

  document.querySelectorAll('.calendar-option').forEach(option => {
    option.addEventListener('click', (e) => {
      e.preventDefault();
      e.stopPropagation();
      const { calendar, title, start, end, location, description } = option.dataset;

      if (calendar === 'google') {
        const url = `https://calendar.google.com/calendar/render?action=TEMPLATE&text=${encodeURIComponent(title)}&dates=${start}/${end}&location=${encodeURIComponent(location)}&details=${encodeURIComponent(description)}`;
        window.open(url, '_blank');
      } else if (calendar === 'ics') {
        const ics = [
          'BEGIN:VCALENDAR',
          'VERSION:2.0',
          'PRODID:-//Class of 1996//Reunion//EN',
          'BEGIN:VEVENT',
          `DTSTART:${start}`,
          `DTEND:${end}`,
          `SUMMARY:${title}`,
          `LOCATION:${location}`,
          `DESCRIPTION:${description}`,
          'END:VEVENT',
          'END:VCALENDAR'
        ].join('\r\n');
        const blob = new Blob([ics], { type: 'text/calendar;charset=utf-8' });
        const link = document.createElement('a');
        link.href = URL.createObjectURL(blob);
        link.download = `${title.replace(/[^a-zA-Z0-9]/g, '_')}.ics`;
        link.click();
        URL.revokeObjectURL(link.href);
      }

      // Close dropdown
      document.querySelectorAll('.calendar-dropdown').forEach(d => d.classList.remove('open'));
      document.querySelectorAll('.calendar-btn').forEach(b => b.setAttribute('aria-expanded', 'false'));
    });
  });
</script>
