---
// About section component - modernized
---

<section class="about" id="about">
  <div class="container">
    <div class="about-content animate-on-scroll">
      <div class="about-text">
        <div class="accent-line"></div>
        <p><span class="small-text">Join us for our class reunion</span><br><span class="large-text">FRIDAY - SUNDAY, SEPTEMBER 4-6, 2026</span><br><span class="small-text">as we reconnect with former classmates and celebrate our time together.</span></p>
        <a href="/rsvp" class="btn btn-primary">RSVP</a>
      </div>
      <div class="about-image-wrapper">
        <div class="about-image">
          <img src="/images/lincoln-east-high-school-lincoln-ne-3-schoolphoto.avif" alt="Lincoln East High School building" />
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .about {
    padding: var(--section-padding) 0;
    background: var(--color-offwhite);
    background-image: var(--gradient-mesh-bg);
  }

  .container {
    max-width: var(--container-max);
    margin: 0 auto;
    padding: 0 20px;
  }

  .about-content {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 60px;
    align-items: center;
  }

  .accent-line {
    width: 40px;
    height: 3px;
    background: var(--gradient-card-border);
    border-radius: 2px;
    margin-bottom: 24px;
  }

  .about-text p {
    font-family: var(--font-body);
    font-weight: 400;
    color: var(--color-gray-500);
    line-height: 1.4;
    margin: 0 0 30px 0;
    max-width: 500px;
  }

  .about-text .small-text {
    font-size: 24px;
  }

  .about-text .large-text {
    font-family: var(--font-display);
    font-size: 40px;
    font-weight: 700;
    color: var(--color-primary-700);
  }

  .about-image-wrapper {
    position: relative;
  }

  .about-image-wrapper::after {
    content: '';
    position: absolute;
    top: 12px;
    left: 12px;
    right: -12px;
    bottom: -12px;
    border-radius: 18px;
    border: 2px solid transparent;
    background: var(--gradient-card-border);
    background-origin: border-box;
    background-clip: border-box;
    z-index: 0;
    opacity: 0.5;
    mask: linear-gradient(#fff 0 0) padding-box, linear-gradient(#fff 0 0);
    mask-composite: exclude;
    -webkit-mask: linear-gradient(#fff 0 0) padding-box, linear-gradient(#fff 0 0);
    -webkit-mask-composite: xor;
  }

  .about-image {
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.1);
    height: 100%;
    position: relative;
    z-index: 1;
  }

  .about-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .btn {
    padding: 16px 32px;
    border-radius: 12px;
    text-decoration: none;
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 16px;
    text-transform: uppercase;
    letter-spacing: 1px;
    transition: all var(--transition-medium);
    display: inline-block;
  }

  .btn-primary {
    background: var(--gradient-primary);
    color: white;
    border: 2px solid transparent;
    box-shadow: 0 4px 15px rgba(6, 182, 212, 0.2);
  }

  .btn-primary:hover {
    transform: translateY(-3px);
    box-shadow: 0 10px 30px rgba(6, 182, 212, 0.3);
  }

  @media (max-width: 768px) {
    .about { padding: var(--section-padding-mobile) 0; }
    .about-content { grid-template-columns: 1fr; gap: 40px; }
    .about-image-wrapper { order: -1; }
    .about-text p { max-width: 100%; }
    .about-text .small-text { font-size: 18px; }
    .about-text .large-text { font-size: 32px; }
    .btn { width: 100%; max-width: 300px; text-align: center; }
  }

  @media (max-width: 480px) {
    .about { padding: 40px 0; }
    .about-content { gap: 30px; }
    .about-text .small-text { font-size: 16px; }
    .about-text .large-text { font-size: 24px; }
    .btn { font-size: 14px; padding: 12px 24px; }
  }
</style>
