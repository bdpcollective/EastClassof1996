---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Banner from '../components/Banner.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout
  title="Early Bird Special | Lincoln East Class of 1996 – 30th Reunion"
  description="Lock in early bird pricing for the Lincoln East Class of 1996 30th Reunion! $35/person or $60/couple. Labor Day Weekend, September 5-6, 2026 in Lincoln, Nebraska."
>
  <Header />
  <Banner />

  <main id="main-content">
    <section class="announce-page ambient-bg">
      <div class="container">

        <!-- Hero Announcement -->
        <div class="announce-hero animate-on-scroll">
          <div class="early-bird-badge">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            Early Bird Special
          </div>
          <h1>30th Reunion<br><span class="highlight">Early Bird Pricing</span></h1>
          <p class="announce-subtitle">The Lincoln East High School Class of 1996 reunion is happening Labor Day Weekend! Sign up early and save.</p>
        </div>

        <!-- Pricing Cards -->
        <div class="pricing-cards animate-on-scroll">
          <div class="pricing-card">
            <div class="card-accent"></div>
            <div class="card-body">
              <h2>Individual</h2>
              <div class="price">
                <span class="amount">$35</span>
                <span class="per">per person</span>
              </div>
              <ul class="perks">
                <li>
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--color-electric)" stroke-width="3" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
                  School Tour (Saturday)
                </li>
                <li>
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--color-electric)" stroke-width="3" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
                  Sunday Social at South Apothecary Loft
                </li>
                <li>
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--color-electric)" stroke-width="3" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
                  Reconnect with classmates
                </li>
              </ul>
              <a href="/register" class="cta-btn">Register Now</a>
            </div>
          </div>

          <div class="pricing-card featured">
            <div class="card-accent"></div>
            <div class="best-value">Best Value</div>
            <div class="card-body">
              <h2>Couple</h2>
              <div class="price">
                <span class="amount">$60</span>
                <span class="per">per couple</span>
              </div>
              <div class="savings">Save $10!</div>
              <ul class="perks">
                <li>
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--color-electric)" stroke-width="3" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
                  School Tour (Saturday)
                </li>
                <li>
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--color-electric)" stroke-width="3" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
                  Sunday Social at South Apothecary Loft
                </li>
                <li>
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--color-electric)" stroke-width="3" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
                  Bring your +1 and save
                </li>
              </ul>
              <a href="/register" class="cta-btn">Register Now</a>
            </div>
          </div>
        </div>

        <!-- Event Details -->
        <div class="event-info animate-on-scroll">
          <h2>What's Happening</h2>
          <div class="event-grid">
            <div class="event-item">
              <div class="event-date-box">
                <span class="day-name">Saturday</span>
                <span class="month">Sept</span>
                <span class="day-number">5</span>
              </div>
              <div class="event-details">
                <h3>School Tour</h3>
                <p>Walk the halls one more time. Meet at Lincoln East High School at 8:00 AM.</p>
                <span class="event-tag free">Free</span>
              </div>
            </div>

            <div class="event-item">
              <div class="event-date-box">
                <span class="day-name">Sunday</span>
                <span class="month">Sept</span>
                <span class="day-number">6</span>
              </div>
              <div class="event-details">
                <h3>Sunday Social</h3>
                <p>The main event! South Apothecary Loft, 7:00 PM. Food, drinks, and 30 years of catching up.</p>
                <span class="event-tag">Included</span>
              </div>
            </div>
          </div>
        </div>

        <!-- CTA Section -->
        <div class="cta-section animate-on-scroll">
          <h2>Don't Wait — Early Bird Pricing Won't Last</h2>
          <p>Register now and pay via Venmo to lock in your discounted rate.</p>
          <div class="cta-buttons">
            <a href="/register" class="cta-btn primary">Register & Pay</a>
            <a href="https://www.facebook.com/sharer/sharer.php?u=https%3A%2F%2Flincolneast1996.com%2Fannounce" target="_blank" rel="noopener noreferrer" class="cta-btn secondary">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
              Share on Facebook
            </a>
          </div>
        </div>

      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>

<style>
  .announce-page {
    padding: var(--section-padding) 0;
    background: var(--gradient-primary);
    min-height: 80vh;
  }

  .announce-page::before {
    z-index: 0;
  }

  .container {
    max-width: 900px;
    margin: 0 auto;
    padding: 0 20px;
    position: relative;
    z-index: 1;
  }

  /* Hero */
  .announce-hero {
    text-align: center;
    margin-bottom: 60px;
  }

  .early-bird-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: rgba(255, 255, 255, 0.15);
    border: 1px solid rgba(255, 255, 255, 0.3);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    padding: 10px 24px;
    border-radius: 50px;
    font-family: var(--font-display);
    font-size: 14px;
    font-weight: 600;
    color: var(--color-electric-light);
    text-transform: uppercase;
    letter-spacing: 2px;
    margin-bottom: 24px;
    animation: pulse-glow 2s ease-in-out infinite;
  }

  @keyframes pulse-glow {
    0%, 100% { box-shadow: 0 0 20px rgba(103, 232, 249, 0.1); }
    50% { box-shadow: 0 0 30px rgba(103, 232, 249, 0.25); }
  }

  .announce-hero h1 {
    font-family: var(--font-display);
    font-size: 52px;
    font-weight: 700;
    color: white;
    margin: 0 0 20px 0;
    text-transform: uppercase;
    letter-spacing: 2px;
    line-height: 1.15;
  }

  .highlight {
    background: linear-gradient(90deg, var(--color-electric-light), var(--color-primary-300));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .announce-subtitle {
    font-family: var(--font-body);
    font-size: 20px;
    font-weight: 300;
    color: rgba(255, 255, 255, 0.9);
    margin: 0;
    max-width: 600px;
    margin-inline: auto;
    line-height: 1.6;
  }

  /* Pricing Cards */
  .pricing-cards {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
    margin-bottom: 60px;
  }

  .pricing-card {
    background: white;
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.15);
    position: relative;
    transition: transform var(--transition-medium), box-shadow var(--transition-medium);
  }

  .pricing-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 28px 50px rgba(0, 0, 0, 0.2);
  }

  .pricing-card.featured {
    border: 2px solid var(--color-electric);
  }

  .card-accent {
    height: 4px;
    background: var(--gradient-primary);
  }

  .featured .card-accent {
    height: 6px;
  }

  .best-value {
    background: var(--color-electric);
    color: white;
    font-family: var(--font-display);
    font-size: 12px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 2px;
    text-align: center;
    padding: 6px;
  }

  .card-body {
    padding: 36px 32px;
    text-align: center;
  }

  .card-body h2 {
    font-family: var(--font-display);
    font-size: 22px;
    font-weight: 600;
    color: var(--color-gray-700);
    margin: 0 0 20px 0;
    text-transform: uppercase;
    letter-spacing: 1px;
  }

  .price {
    margin-bottom: 8px;
  }

  .amount {
    font-family: var(--font-display);
    font-size: 56px;
    font-weight: 700;
    color: var(--color-primary-700);
    line-height: 1;
  }

  .per {
    display: block;
    font-family: var(--font-body);
    font-size: 15px;
    color: var(--color-gray-500);
    margin-top: 4px;
  }

  .savings {
    display: inline-block;
    background: rgba(6, 182, 212, 0.1);
    color: var(--color-electric);
    font-family: var(--font-display);
    font-size: 13px;
    font-weight: 700;
    padding: 4px 14px;
    border-radius: 50px;
    margin-bottom: 16px;
    text-transform: uppercase;
    letter-spacing: 1px;
  }

  .perks {
    list-style: none;
    padding: 0;
    margin: 24px 0 32px;
    text-align: left;
  }

  .perks li {
    display: flex;
    align-items: center;
    gap: 10px;
    font-family: var(--font-body);
    font-size: 15px;
    color: var(--color-gray-700);
    padding: 8px 0;
    border-bottom: 1px solid var(--color-gray-100);
  }

  .perks li:last-child {
    border-bottom: none;
  }

  .perks li svg {
    flex-shrink: 0;
  }

  .cta-btn {
    display: inline-block;
    background: var(--gradient-primary);
    color: white;
    padding: 14px 32px;
    border-radius: 12px;
    font-family: var(--font-display);
    font-size: 15px;
    font-weight: 600;
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 1px;
    transition: all var(--transition-medium);
    box-shadow: 0 4px 15px rgba(6, 182, 212, 0.2);
  }

  .cta-btn:hover {
    transform: translateY(-3px);
    box-shadow: 0 10px 30px rgba(6, 182, 212, 0.3);
  }

  /* Event Info */
  .event-info {
    background: white;
    border-radius: 16px;
    padding: 40px;
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.15);
    margin-bottom: 60px;
  }

  .event-info h2 {
    font-family: var(--font-display);
    font-size: 28px;
    font-weight: 600;
    color: var(--color-primary-700);
    margin: 0 0 32px 0;
    text-align: center;
    text-transform: uppercase;
    letter-spacing: 1px;
  }

  .event-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
  }

  .event-item {
    display: flex;
    gap: 16px;
    padding: 20px;
    border: 1px solid var(--color-gray-100);
    border-radius: 12px;
    transition: border-color var(--transition-fast);
  }

  .event-item:hover {
    border-color: var(--color-electric);
  }

  .event-date-box {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    background: var(--gradient-primary);
    border-radius: 10px;
    padding: 12px 16px;
    min-width: 72px;
    flex-shrink: 0;
  }

  .day-name {
    font-family: var(--font-display);
    font-size: 10px;
    font-weight: 600;
    color: rgba(255, 255, 255, 0.8);
    text-transform: uppercase;
    letter-spacing: 1px;
  }

  .month {
    font-family: var(--font-display);
    font-size: 12px;
    font-weight: 600;
    color: var(--color-electric-light);
    text-transform: uppercase;
  }

  .day-number {
    font-family: var(--font-display);
    font-size: 28px;
    font-weight: 700;
    color: white;
    line-height: 1;
  }

  .event-details h3 {
    font-family: var(--font-display);
    font-size: 18px;
    font-weight: 600;
    color: var(--color-gray-900);
    margin: 0 0 6px 0;
  }

  .event-details p {
    font-family: var(--font-body);
    font-size: 14px;
    color: var(--color-gray-500);
    margin: 0 0 10px 0;
    line-height: 1.5;
  }

  .event-tag {
    display: inline-block;
    font-family: var(--font-display);
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1px;
    padding: 3px 10px;
    border-radius: 50px;
    background: rgba(6, 182, 212, 0.1);
    color: var(--color-electric);
  }

  .event-tag.free {
    background: rgba(34, 197, 94, 0.1);
    color: #16a34a;
  }

  /* CTA Section */
  .cta-section {
    text-align: center;
    padding: 48px 32px;
    background: rgba(255, 255, 255, 0.08);
    border: 1px solid rgba(255, 255, 255, 0.15);
    border-radius: 16px;
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }

  .cta-section h2 {
    font-family: var(--font-display);
    font-size: 28px;
    font-weight: 600;
    color: white;
    margin: 0 0 12px 0;
  }

  .cta-section p {
    font-family: var(--font-body);
    font-size: 17px;
    color: rgba(255, 255, 255, 0.85);
    margin: 0 0 32px 0;
  }

  .cta-buttons {
    display: flex;
    gap: 16px;
    justify-content: center;
    flex-wrap: wrap;
  }

  .cta-btn.primary {
    background: white;
    color: var(--color-primary-700);
    box-shadow: 0 4px 20px rgba(255, 255, 255, 0.2);
  }

  .cta-btn.primary:hover {
    box-shadow: 0 10px 40px rgba(255, 255, 255, 0.3);
  }

  .cta-btn.secondary {
    background: transparent;
    border: 2px solid rgba(255, 255, 255, 0.4);
    color: white;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    box-shadow: none;
  }

  .cta-btn.secondary:hover {
    border-color: white;
    background: rgba(255, 255, 255, 0.1);
    box-shadow: none;
  }

  /* Responsive */
  @media (max-width: 768px) {
    .announce-hero h1 {
      font-size: 34px;
    }

    .announce-subtitle {
      font-size: 17px;
    }

    .pricing-cards {
      grid-template-columns: 1fr;
      max-width: 400px;
      margin-inline: auto;
      margin-bottom: 60px;
    }

    .event-grid {
      grid-template-columns: 1fr;
    }

    .event-info {
      padding: 30px 20px;
    }

    .cta-section {
      padding: 36px 20px;
    }

    .cta-section h2 {
      font-size: 22px;
    }

    .cta-buttons {
      flex-direction: column;
      align-items: center;
    }

    .cta-btn {
      width: 100%;
      text-align: center;
      justify-content: center;
    }
  }

  @media (max-width: 480px) {
    .announce-page {
      padding: 40px 0;
    }

    .announce-hero h1 {
      font-size: 28px;
    }

    .amount {
      font-size: 44px;
    }

    .card-body {
      padding: 28px 20px;
    }
  }
</style>
