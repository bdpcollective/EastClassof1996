---
export interface Props {
  title: string;
  description: string;
  ogImage?: string;
}

const { title, description, ogImage = 'https://static.wixstatic.com/media/4c7a9c_a04a64850b9f47c7adff59cfdc024a99~mv2.jpg/v1/fill/w_2500,h_1666,al_c/4c7a9c_a04a64850b9f47c7adff59cfdc024a99~mv2.jpg' } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=Inter:wght@300;400;500;600&family=Noto+Serif:wght@400;700&display=swap" rel="stylesheet">
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
  </head>
  <body>
    <a href="#main-content" class="skip-link">Skip to main content</a>
    <slot />

    <script>
      const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      // Smooth page transitions
      function initPageTransitions() {
        if (prefersReducedMotion) return;
        const links = document.querySelectorAll('a[href^="/"], a[href^="./"], a[href^="../"]');

        links.forEach(link => {
          link.addEventListener('click', (e) => {
            const href = link.getAttribute('href');
            if (!href || href.startsWith('http') || href === window.location.pathname) return;

            e.preventDefault();
            document.body.style.opacity = '0';
            document.body.style.transition = 'opacity 0.3s ease-out';

            setTimeout(() => {
              window.location.href = href;
            }, 300);
          });
        });
      }

      // Page fade in
      function fadeInPage() {
        if (prefersReducedMotion) { document.body.style.opacity = '1'; return; }
        document.body.style.opacity = '0';
        document.body.style.transition = 'opacity 0.3s ease-in';
        setTimeout(() => {
          document.body.style.opacity = '1';
        }, 50);
      }

      // Scroll-triggered animations
      function initScrollAnimations() {
        const observer = new IntersectionObserver((entries) => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              entry.target.classList.add('is-visible');
              observer.unobserve(entry.target);
            }
          });
        }, { threshold: 0.1, rootMargin: '0px 0px -50px 0px' });

        document.querySelectorAll('.animate-on-scroll').forEach(el => {
          observer.observe(el);
        });
      }

      document.addEventListener('DOMContentLoaded', () => {
        fadeInPage();
        initPageTransitions();
        initScrollAnimations();
      });
    </script>
  </body>
</html>

<style is:global>
  :root {
    /* Primary blues */
    --color-primary-900: #1e2a78;
    --color-primary-700: #1e40af;
    --color-primary-500: #3b82f6;
    --color-primary-300: #93c5fd;
    --color-primary-100: #dbeafe;

    /* Electric accent */
    --color-electric: #06b6d4;
    --color-electric-light: #67e8f9;

    /* Warm accents */
    --color-coral: #f97316;
    --color-coral-light: #fdba74;
    --color-gold: #eab308;

    /* Neutrals */
    --color-white: #ffffff;
    --color-offwhite: #f8fafc;
    --color-gray-100: #f1f5f9;
    --color-gray-300: #cbd5e1;
    --color-gray-500: #64748b;
    --color-gray-700: #334155;
    --color-gray-900: #0f172a;

    /* Gradients */
    --gradient-primary: linear-gradient(135deg, #1e2a78 0%, #3b82f6 50%, #06b6d4 100%);
    --gradient-hero: linear-gradient(135deg, rgba(30, 42, 120, 0.85) 0%, rgba(6, 182, 212, 0.7) 100%);
    --gradient-card-border: linear-gradient(135deg, #3b82f6, #06b6d4, #f97316);
    --gradient-mesh-bg:
      radial-gradient(ellipse at 20% 80%, rgba(6, 182, 212, 0.12) 0%, transparent 50%),
      radial-gradient(ellipse at 80% 20%, rgba(59, 130, 246, 0.08) 0%, transparent 50%),
      radial-gradient(ellipse at 50% 50%, rgba(249, 115, 22, 0.04) 0%, transparent 50%);

    /* Typography */
    --font-display: 'Space Grotesk', sans-serif;
    --font-body: 'Inter', sans-serif;
    --font-accent: 'Noto Serif', serif;

    /* Transitions */
    --ease-out-expo: cubic-bezier(0.16, 1, 0.3, 1);
    --transition-fast: 0.2s cubic-bezier(0.16, 1, 0.3, 1);
    --transition-medium: 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    --transition-slow: 0.6s cubic-bezier(0.16, 1, 0.3, 1);

    /* Effects */
    --glass-bg: rgba(255, 255, 255, 0.08);
    --glass-border: rgba(255, 255, 255, 0.15);
    --glass-blur: blur(12px);

    /* Layout */
    --section-padding: 100px;
    --section-padding-mobile: 60px;
    --container-max: 1200px;
  }

  html {
    font-family: var(--font-body);
    color: var(--color-gray-700);
    overflow-x: hidden;
  }

  body {
    margin: 0;
    padding: 0;
    overflow-x: hidden;
    min-width: 320px;
  }

  * {
    box-sizing: border-box;
  }

  h1, h2, h3, h4 {
    font-family: var(--font-display);
  }

  /* Scroll animations */
  .animate-on-scroll {
    opacity: 0;
    transform: translateY(30px);
    transition: opacity 0.6s var(--ease-out-expo), transform 0.6s var(--ease-out-expo);
  }

  .animate-on-scroll.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  .animate-on-scroll.stagger.is-visible > * {
    opacity: 1;
    transform: translateY(0);
  }

  .animate-on-scroll.stagger > *:nth-child(1) { transition-delay: 0s; }
  .animate-on-scroll.stagger > *:nth-child(2) { transition-delay: 0.1s; }
  .animate-on-scroll.stagger > *:nth-child(3) { transition-delay: 0.15s; }
  .animate-on-scroll.stagger > *:nth-child(4) { transition-delay: 0.2s; }

  .animate-on-scroll.stagger > * {
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.5s var(--ease-out-expo), transform 0.5s var(--ease-out-expo);
  }

  /* Ambient background effect (replaces particles) */
  .ambient-bg {
    position: relative;
  }

  .ambient-bg::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse at 20% 50%, rgba(6, 182, 212, 0.12) 0%, transparent 50%),
      radial-gradient(ellipse at 80% 50%, rgba(249, 115, 22, 0.06) 0%, transparent 50%),
      radial-gradient(ellipse at 50% 0%, rgba(59, 130, 246, 0.08) 0%, transparent 50%);
    animation: ambient-shift 20s ease-in-out infinite alternate;
    pointer-events: none;
    z-index: 0;
  }

  @keyframes ambient-shift {
    0% { opacity: 0.6; transform: scale(1); }
    50% { opacity: 1; transform: scale(1.05); }
    100% { opacity: 0.6; transform: scale(1); }
  }

  /* Prevent body scroll when menu is open */
  body.menu-open {
    overflow: hidden;
  }

  /* Skip navigation link */
  .skip-link {
    position: absolute;
    top: -100%;
    left: 50%;
    transform: translateX(-50%);
    background: var(--color-primary-700);
    color: white;
    padding: 12px 24px;
    border-radius: 0 0 8px 8px;
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 14px;
    text-decoration: none;
    z-index: 10000;
    transition: top 0.2s ease;
  }

  .skip-link:focus {
    top: 0;
  }

  /* Global focus-visible styles */
  :focus-visible {
    outline: 3px solid var(--color-electric);
    outline-offset: 2px;
  }

  :focus:not(:focus-visible) {
    outline: none;
  }

  /* Prefers reduced motion */
  @media (prefers-reduced-motion: reduce) {
    *,
    *::before,
    *::after {
      animation-duration: 0.01ms !important;
      animation-iteration-count: 1 !important;
      transition-duration: 0.01ms !important;
      scroll-behavior: auto !important;
    }

    .animate-on-scroll {
      opacity: 1;
      transform: none;
    }

    .animate-on-scroll.stagger > * {
      opacity: 1;
      transform: none;
    }
  }

  /* Backdrop filter fallback */
  @supports not (backdrop-filter: blur(1px)) {
    .glass-fallback {
      background: rgba(255, 255, 255, 0.95) !important;
    }
  }
</style>
