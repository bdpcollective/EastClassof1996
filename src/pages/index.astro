---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Banner from '../components/Banner.astro';
import Countdown from '../components/Countdown.astro';
import ReunionEvents from '../components/ReunionEvents.astro';
import Memories from '../components/Memories.astro';
import About from '../components/About.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout
  title="Lincoln East High School Class of 1996 | 30th Reunion"
  description="Join us for the Lincoln East High School Class of 1996 30th Reunion! September 5-6, 2026 in Lincoln, Nebraska. Reconnect with classmates, share memories, and celebrate 30 years since graduation."
>
  <Header />
  <Banner />
  <Countdown />
  <main id="main-content">
    <About />
    <ReunionEvents />
    <Memories />
  </main>
  <Footer />
</BaseLayout>
