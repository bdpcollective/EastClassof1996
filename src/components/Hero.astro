---
// Hero section component - modernized
---

<section class="hero" id="home">
  <div class="hero-background">
    <div class="hero-overlay"></div>
  </div>
  <div class="container">
    <div class="hero-content">
      <div class="hero-badge">
        <span>30th Reunion &bull; Saturday &amp; Sunday, September 5-6, 2026</span>
      </div>
      <h1 class="hero-title">
        <span class="hero-subtitle">Lincoln East High School Class of 1996</span>
        <span class="hero-location">LINCOLN, NEBRASKA<br>SATURDAY &amp; SUNDAY, SEPTEMBER 5-6, 2026</span>
      </h1>
      <h2 class="hero-main-title">30 Years of Memories, Friendships & Adventures</h2>
      <p class="hero-tagline">Reconnect with classmates and celebrate three decades of life after high school.</p>
      <div class="hero-cta">
        <a href="/events" class="btn btn-primary btn-large">VIEW EVENTS</a>
        <a href="/rsvp" class="btn btn-secondary btn-large">RSVP NOW</a>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    overflow: hidden;
  }

  .hero-background {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: url('https://static.wixstatic.com/media/4c7a9c_a04a64850b9f47c7adff59cfdc024a99~mv2.jpg/v1/fill/w_2500,h_1666,al_c/4c7a9c_a04a64850b9f47c7adff59cfdc024a99~mv2.jpg') center/cover;
    z-index: 1;
  }

  .hero-overlay {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: var(--gradient-hero);
    z-index: 2;
  }

  .container {
    position: relative;
    z-index: 3;
    max-width: var(--container-max);
    margin: 0 auto;
    padding: 0 20px;
  }

  .hero-content {
    text-align: center;
    color: white;
    max-width: 800px;
    margin: 0 auto;
  }

  .hero-badge {
    background: rgba(255, 255, 255, 0.1);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    border: 1px solid rgba(255, 255, 255, 0.2);
    padding: 10px 24px;
    border-radius: 50px;
    display: inline-block;
    margin-bottom: 30px;
    font-family: var(--font-body);
    font-size: 14px;
    font-weight: 500;
    letter-spacing: 0.5px;
  }

  .hero-title {
    margin-bottom: 20px;
  }

  .hero-subtitle {
    display: block;
    font-family: var(--font-display);
    font-size: 18px;
    font-weight: 600;
    margin-bottom: 10px;
    opacity: 0.9;
  }

  .hero-location {
    display: block;
    font-family: var(--font-body);
    font-size: 16px;
    font-weight: 400;
    opacity: 0.8;
    line-height: 1.4;
  }

  .hero-main-title {
    font-family: var(--font-display);
    font-size: 48px;
    font-weight: 700;
    line-height: 1.2;
    margin: 30px 0;
  }

  .hero-tagline {
    font-family: var(--font-body);
    font-size: 20px;
    font-weight: 300;
    margin-bottom: 40px;
    opacity: 0.9;
  }

  .hero-cta {
    display: flex;
    gap: 20px;
    justify-content: center;
    flex-wrap: wrap;
  }

  .btn {
    padding: 16px 32px;
    border-radius: 12px;
    text-decoration: none;
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 16px;
    transition: all var(--transition-medium);
    display: inline-block;
  }

  .btn-large {
    padding: 18px 40px;
    font-size: 17px;
  }

  .btn-primary {
    background: var(--gradient-primary);
    color: white;
    border: 2px solid transparent;
  }

  .btn-primary:hover {
    transform: translateY(-3px);
    box-shadow: 0 10px 30px rgba(6, 182, 212, 0.3);
  }

  .btn-secondary {
    background: rgba(255, 255, 255, 0.1);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    color: white;
    border: 1px solid rgba(255, 255, 255, 0.3);
  }

  .btn-secondary:hover {
    background: rgba(255, 255, 255, 0.2);
    transform: translateY(-3px);
    box-shadow: 0 10px 30px rgba(255, 255, 255, 0.15);
  }

  @media (max-width: 768px) {
    .hero-main-title { font-size: 36px; }
    .hero-tagline { font-size: 18px; }
    .hero-cta { flex-direction: column; align-items: center; }
    .btn-large { width: 100%; max-width: 300px; text-align: center; }
  }

  @media (max-width: 480px) {
    .hero-main-title { font-size: 28px; }
    .hero-tagline { font-size: 16px; }
  }
</style>
